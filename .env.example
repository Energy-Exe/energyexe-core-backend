# Environment Configuration
DEBUG=true
LOG_LEVEL=DEBUG

DATABASE_URL=postgresql+asyncpg://energyexe:password@db:5432/energyexe_db
# Security
SECRET_KEY=your-secret-key-here-change-in-production

# Server Configuration
HOST=127.0.0.1
PORT=8000
RELOAD=true

# CORS Origins (for development) - JSON array format
BACKEND_CORS_ORIGINS=["*"]

# Redis (Docker Compose)
REDIS_URL=redis://localhost:6379

# Email (Resend) — leave RESEND_API_KEY blank to no-op email sends in dev
RESEND_API_KEY=
EMAILS_FROM_EMAIL=noreply@energyexe.com
EMAILS_FROM_NAME=EnergyExe
SUPPORT_EMAIL=hello@energyexe.com

# Portal URLs used in transactional email links (verify, reset, invite)
CLIENT_PORTAL_URL=http://localhost:3000
ADMIN_PORTAL_URL=http://localhost:3005